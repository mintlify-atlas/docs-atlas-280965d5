  "keyFeatures": [
    "Real-time voice interaction with hands-free conversation and voice interruption",
    "Live2D avatar with expression and motion control",
    "Completely offline operation — all components can run locally",
    "Cross-platform: Windows, macOS, and Linux",
    "Web and desktop client modes, including transparent desktop pet mode",
    "Visual perception: camera, screen recording, and screenshots",
    "Support for any LLM via OpenAI-compatible API, Ollama, Claude, Gemini, and more",
    "Modular ASR backends: Sherpa-ONNX, Faster-Whisper, FunASR, Azure, Groq",
    "Modular TTS backends: Edge TTS, GPT-SoVITS, CosyVoice, ElevenLabs, Azure, and more",
    "MCP (Model Context Protocol) tool integration",
    "Group conversation support with multiple AI participants",
    "Chat history persistence and session switching",
    "TTS translation (speak in one language, AI responds in another)",
    "Character customization: Live2D models, persona prompts, voice cloning"
  ],
  "publicApiSurface": [
    "WebSocket server at ws://localhost:12393 (main client endpoint)",
    "WebSocket proxy endpoint at /proxy-ws",
    "FastAPI HTTP server serving frontend and static assets",
    "AgentInterface — base class for custom agent implementations",
    "ASRInterface — base class for custom ASR engine implementations",
    "TTSInterface — base class for custom TTS engine implementations",
    "agent_factory.py — factory for creating agent instances from config",
    "asr_factory.py — factory for creating ASR engine instances from config",
    "tts_factory.py — factory for creating TTS engine instances from config",
    "ServiceContext — central dependency injection container per WebSocket connection",
    "conf.yaml — main user configuration file (YAML)",
    "characters/*.yaml — character-specific configuration files",
    "model_dict.json — registry of available Live2D models"
  ]
}
